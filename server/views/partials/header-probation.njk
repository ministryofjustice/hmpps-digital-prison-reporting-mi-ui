{# MoJ Design System — PDS header (probation): https://design-patterns.service.justice.gov.uk/probation/components/pds-header/ #}
{% from "domain-specific/probation/header/macro.njk" import pdsHeader %}

<div data-qa="pds-header">
  {{ pdsHeader({
    environmentName: 'PRODUCTION',
    name: (user.displayName | initialiseName) if user else 'User',
    manageDetailsLink: '/account-details',
    servicesLink: '/',
    services: [{ heading: applicationName, href: '/', target: '_self' }],
    titleLink: '/'
  }) }}
</div>
